# Build artifacts
/bin/
/dist/
# Anchored to repo root (leading slash) — a bare "click"/"click.exe" pattern would also match
# ANY nested path named "click", including cmd/click/, silently excluding it from git entirely.
# (This is exactly what happened: cmd/click/main.go was never committed until this fix.)
/click
/click.exe
*.exe
*.test
*.out

# Go
vendor/

# Env / secrets
.env
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local SDD skill-registry cache (regenerated by sdd-init, machine-local)
.atl/

# Local CodeGraph index (machine-local, regenerated per checkout — never shared)
.codegraph/
